---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Aditya Sunil Nair - Senior Product Manager, Fintech & AI-Driven Delivery',
  description = 'Aditya Sunil Nair, Senior Product Manager across fintech, payments, and AI-driven product delivery. 11+ years spanning engineering and product.'
} = Astro.props;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;9..144,500;9..144,600;9..144,700&family=IBM+Plex+Mono:wght@400;500;600&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
</head>
<body>
  <header class="site">
    <div class="navbar">
      <a href="#top" class="brand"><span class="dot"></span>ADITYA.NAIR</a>
      <nav class="links">
        <a href="#about">About</a>
        <a href="#ledger">Career Ledger</a>
        <a href="#capabilities">Capabilities</a>
        <a href="#skills">Toolkit</a>
        <a href="#contact">Contact</a>
      </nav>
    </div>
  </header>

  <div class="wrap">
    <slot />
  </div>

  <script>
    const els = document.querySelectorAll('[data-reveal]');
    const io = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) {
          e.target.classList.add('in');
          io.unobserve(e.target);
        }
      });
    }, { threshold: 0.12 });
    els.forEach((el) => io.observe(el));
  </script>
</body>
</html>
