From e3c482b72e4c2a52ac489fca3df27e15afa45589 Mon Sep 17 00:00:00 2001
From: Aditya Sunil Nair <adit_nair@hotmail.com>
Date: Tue, 14 Jul 2026 11:13:38 +0000
Subject: [PATCH] Fix project card header alignment: stack title above
 company/year row consistently

---
 src/styles/global.css | 16 ++++++++--------
 1 file changed, 8 insertions(+), 8 deletions(-)

diff --git a/src/styles/global.css b/src/styles/global.css
index 183cf5f..937b661 100644
--- a/src/styles/global.css
+++ b/src/styles/global.css
@@ -248,18 +248,18 @@ footer .fine{ text-align:center; margin-top:44px; font-family:var(--mono); font-
 .project-card:hover{ border-color:var(--signal); transform:translateY(-2px); }
 
 .project-card-header{
-  display:flex; align-items:flex-start; justify-content:space-between; gap:16px;
-  padding-bottom:18px; border-bottom:1px solid var(--line-soft); flex-wrap:wrap;
+  padding-bottom:18px; border-bottom:1px solid var(--line-soft);
 }
 .project-name{
   font-family:var(--serif); font-weight:600; font-size:19px; line-height:1.3;
-  margin:0; max-width:60%;
+  margin:0 0 10px; max-width:100%;
 }
-@media (max-width:480px){ .project-name{ max-width:100%; } }
-.project-meta{ text-align:right; font-family:var(--mono); font-size:12px; color:var(--muted-2); line-height:1.6; }
-@media (max-width:480px){ .project-meta{ text-align:left; } }
-.project-meta .p-company{ color:var(--gold); display:block; }
-.project-meta .p-year{ display:block; }
+.project-meta{
+  display:flex; align-items:baseline; justify-content:space-between; flex-wrap:wrap;
+  gap:6px 14px; font-family:var(--mono); font-size:12px; color:var(--muted-2);
+}
+.project-meta .p-company{ color:var(--gold); }
+.project-meta .p-year{ white-space:nowrap; }
 
 .project-desc{ color:var(--muted); font-size:14.5px; margin:0; }
 
-- 
2.43.0

