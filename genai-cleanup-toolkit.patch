-  color:var(--muted-2); margin:0 0 14px;
-}
-.chips{ display:flex; flex-wrap:wrap; gap:9px; }
-.chip{
-  font-size:13.5px; padding:7px 13px; border:1px solid var(--line); border-radius:100px; color:var(--text);
-  background:var(--surface);
+  color:var(--muted-2); margin:0 0 8px;
 }
+.skill-line{ margin:0; color:var(--text); font-size:14px; line-height:1.65; }
 
 /* ---------- Education ---------- */
 .edu-grid{ display:grid; grid-template-columns:1fr 1fr; gap:22px; }
